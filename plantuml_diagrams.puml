' ============================================================================
' 3.3.6 SYSTEM ARCHITECTURE DIAGRAM
' ============================================================================
@startuml 3.3.6_system_architecture_diagram
!define RECTANGLE class

package "Frontend Layer" {
  RECTANGLE "React + TypeScript" as React
  RECTANGLE "Tailwind CSS" as Tailwind
  RECTANGLE "Responsive UI" as UI
}

package "Data Management Layer" {
  RECTANGLE "Repository Pattern" as Repo
  RECTANGLE "Decoupled Data Sources" as Data
  RECTANGLE "Business Rules + Reports" as Business
}

package "Data Architecture" {
  RECTANGLE "TypeScript Interfaces" as Interfaces
  RECTANGLE "Entities & Relationships" as Entities
  RECTANGLE "ERD-aligned" as ERD
}

package "Backend Integration (Planned)" #LightGray {
  RECTANGLE "REST/GraphQL API" as API
  RECTANGLE "Auth / Persistence" as Auth
}

package "Database Integration (Planned)" #LightGray {
  RECTANGLE "PostgreSQL / MySQL" as DB
  RECTANGLE "or other DBMS" as DBMS
}

React --> Repo
Tailwind --> Data
UI --> Business

Repo --> Interfaces
Data --> Entities
Business --> ERD

Interfaces ..> API : future
Entities ..> Auth : future
ERD ..> DB : future

API --> DB
Auth --> DBMS

@enduml

