' ============================================================================
' 3.3.5.1 ACTIVITY DIAGRAM - STUDENT
' ============================================================================
@startuml 3.3.5.1_activity_diagram_student
start

:Login to System;
:View Dashboard;
:Select Service;

partition "Student Services" {
  :View Academic Registration;
  :View Grades;
  :View Fees;
  :View ID Card;
  :View Schedule;
  :View Attendance;
  :Submit Registration Issue Form;
  
  if (Issue Resolved?) then (yes)
    :View Academic Warnings;
    stop
  else (no)
    :Wait for Resolution;
    :View Academic Warnings;
    stop
  endif
}

stop

@enduml

' ============================================================================
' 3.3.5.2 ACTIVITY DIAGRAM - FACULTY ADMIN
' ============================================================================
@startuml 3.3.5.2_activity_diagram_professor
start

:Login to System;
:View Dashboard;
:Select Tab\n(Students/Registration/etc);

partition "Faculty Admin Tasks" {
  :Manage Students Data;
  :Enter Grades;
  :Manage Academic Registration;
  :Enter Attendance;
  :Manage Schedules;
  :Manage Courses;
  :Manage Report Signatures;
  :View Activity Log;
}

stop

@enduml

' ============================================================================
' 3.3.5.3 ACTIVITY DIAGRAM - ADVISOR
' ============================================================================
@startuml 3.3.5.3_activity_diagram_advisor
start

:Login to System;
:View Registration Requests;
:Review Student Records;
:Check Prerequisites;

if (Approve?) then (yes)
  :Approve Registration;
  :Notify Student;
  stop
else (no)
  :Reject Registration;
  :Notify Student;
  stop
endif

@enduml

' ============================================================================
' 3.3.5.4 ACTIVITY DIAGRAM - ADMINISTRATOR
' ============================================================================
@startuml 3.3.5.4_activity_diagram_administrator
start

:Login to System;
:Select Action;

partition "Administrator Tasks" {
  :Manage Users;
  :Manage Courses;
  :System Configuration;
  :View System Logs;
}

stop

@enduml

' ============================================================================
' 3.3.5.5 ACTIVITY DIAGRAM - ABSENCE WARNING
' ============================================================================
@startuml 3.3.5.5_activity_diagram_absence_warning
start

:Check Student Absences;
:Calculate Absence Rate;
:Generate Warning;

if (Rate > Threshold?) then (yes)
  :Send Warning to Student;
  :Notify Academic Advisor;
  stop
else (no)
  :No Action Required;
  stop
endif

@enduml

' ============================================================================
' 3.3.5.6 ACTIVITY DIAGRAM - ACADEMIC WARNING
' ============================================================================
@startuml 3.3.5.6_activity_diagram_academic_warning
start

:Calculate Student GPA;
:Generate Academic Warning;

if (GPA < Minimum?) then (yes)
  :Send Warning to Student;
  :Notify Academic Advisor;
  :Schedule Meeting;
  stop
else (no)
  :No Action Required;
  stop
endif

@enduml

' ============================================================================
' 3.3.5.7 ACTIVITY DIAGRAM - COMMITTEE MANAGEMENT
' ============================================================================
@startuml 3.3.5.7_activity_diagram_committee_management
start

:Login to System;
:Navigate to Committee\nDefinition;
:Select Auto-Generate\nor Manual;

if (Auto-Generate Selected?) then (yes)
  :Get Student Enrollments;
  :Group by Course;
  :Assign to Rooms;
  :Generate Seating\nArrangements;
  :Save Committees\nand Assignments;
  stop
else (no)
  :Manual Definition;
  :Save Committees\nand Assignments;
  stop
endif

@enduml

' ============================================================================
' 3.3.6.1 SEQUENCE DIAGRAM - STUDENT
' ============================================================================
@startuml 3.3.6.1_sequence_diagram_student
actor Student
participant "LoginPage" as Login
participant "App" as App
participant "ContentArea" as Content
participant "Database" as DB

Student -> Login : 1. Login Request
Login -> App : 2. Authenticate
App -> DB : 3. Verify User
DB --> App : 4. User Data
App -> Content : 5. Render ContentArea
Content -> DB : 6. Fetch Student Data
DB --> Content : 7. Return Data
Content --> Student : 8. Display Dashboard

@enduml

' ============================================================================
' 3.3.6.2 SEQUENCE DIAGRAM - FACULTY ADMIN
' ============================================================================
@startuml 3.3.6.2_sequence_diagram_professor
actor "Faculty Admin" as Admin
participant "App" as App
participant "ContentArea" as Content
participant "DynamicPage" as Dynamic
participant "Database" as DB

Admin -> App : 1. Select Tab
App -> Content : 2. Navigate
Content -> Dynamic : 3. Load Page
Dynamic -> DB : 4. Query Data
DB --> Dynamic : 5. Return Data
Dynamic -> Content : 6. Render Table
Content --> Admin : 7. Display Content

@enduml

' ============================================================================
' 3.3.6.3 SEQUENCE DIAGRAM - ADVISOR
' ============================================================================
@startuml 3.3.6.3_sequence_diagram_advisor
actor Advisor
participant "App" as App
participant "ContentArea" as Content
participant "Database" as DB
participant Student

Advisor -> App : 1. View Requests
App -> Content : 2. Load Page
Content -> DB : 3. Query Requests
DB --> Content : 4. Return Data
Content --> Advisor : 5. Display Requests
Advisor -> App : 6. Approve/Reject
App -> DB : 7. Update Status
DB -> Student : 8. Notify Student

@enduml

' ============================================================================
' 3.3.6.4 SEQUENCE DIAGRAM - ADMINISTRATOR
' ============================================================================
@startuml 3.3.6.4_sequence_diagram_administrator
actor Administrator
participant "App" as App
participant "System" as System
participant "Database" as DB
participant "Activity Log" as Log

Administrator -> App : 1. System Update
App -> System : 2. Process Update
System -> DB : 3. Update Database
DB --> System : 4. Confirm Update
System -> Log : 5. Log Activity
Log --> System : 6. Logged
System --> App : 7. Update Success
App --> Administrator : 8. Confirmation

@enduml

' ============================================================================
' 3.3.6.5 SEQUENCE DIAGRAM - CONTROLLER
' ============================================================================
@startuml 3.3.6.5_sequence_diagram_controller
participant Controller
participant "System" as System
participant "Database" as DB
participant "Warning Service" as Warning
participant Student

Controller -> System : 1. Monitor System
System -> DB : 2. Query Data
DB --> System : 3. Return Status
System --> Controller : 4. System Status
Controller -> System : 5. Generate Warnings
System -> DB : 6. Check Absences/Grades
DB --> System : 7. Return Data
System -> Warning : 8. Create Warning
Warning -> Student : 9. Send Warning

@enduml

' ============================================================================
' 3.3.6.6 SEQUENCE DIAGRAM - COMMITTEE GENERATION
' ============================================================================
@startuml 3.3.6.6_sequence_diagram_committee_generation
actor Admin
participant "Committee\nDefinition" as Committee
