' ============================================================================
' DUMLIS - PlantUML Diagram Prompts
' ============================================================================
' This file contains all PlantUML prompts for generating DUMLIS diagrams
' Copy each @startuml/@enduml block to generate the corresponding diagram
' ============================================================================

' ============================================================================
' 3.3.3 CONTEXT DIAGRAM
' ============================================================================
@startuml 3.3.3_context_diagram
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle

' ===== ACTORS =====
rectangle "Student" as Student
rectangle "Faculty Admin" as Admin
rectangle "Super Admin" as SuperAdmin
rectangle "External Analytics System" as Analytics
rectangle "IoT / External Services" as ExternalServices

' ===== SYSTEM =====
circle "DUMLIS\nUniversity Management System" as DUMLIS

' ===== STUDENT FLOWS =====
Student --> DUMLIS : register
Student --> DUMLIS : login
Student --> DUMLIS : view grades
Student --> DUMLIS : view schedule
Student --> DUMLIS : view fees
Student --> DUMLIS : view attendance
Student --> DUMLIS : submit registration issue
Student --> DUMLIS : view committee assignment
Student --> DUMLIS : logout

DUMLIS --> Student : academic data
DUMLIS --> Student : notifications
DUMLIS --> Student : reports

' ===== FACULTY ADMIN FLOWS =====
Admin --> DUMLIS : login
Admin --> DUMLIS : manage students
Admin --> DUMLIS : manage courses
Admin --> DUMLIS : enter grades
Admin --> DUMLIS : enter attendance
Admin --> DUMLIS : manage schedules
Admin --> DUMLIS : generate reports
Admin --> DUMLIS : manage exam committees
Admin --> DUMLIS : global search

DUMLIS --> Admin : attendance records
DUMLIS --> Admin : student reports
DUMLIS --> Admin : activity logs

' ===== SUPER ADMIN FLOWS =====
SuperAdmin --> DUMLIS : login
SuperAdmin --> DUMLIS : manage academic structure
SuperAdmin --> DUMLIS : system configuration
SuperAdmin --> DUMLIS : view faculty analytics

DUMLIS --> SuperAdmin : analytics reports
DUMLIS --> SuperAdmin : system status

' ===== EXTERNAL SYSTEM FLOWS =====
Analytics --> DUMLIS : performance data
DUMLIS --> Analytics : academic statistics

ExternalServices --> DUMLIS : external services data
DUMLIS --> ExternalServices : service requests

@enduml

' ============================================================================
