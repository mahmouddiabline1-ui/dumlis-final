  package "Financial & Reports" {
    usecase "Manage Fees" as UC21
    usecase "View Reports" as UC22
    usecase "Financial Reports" as UC23
    usecase "View Activity Log" as UC24
  }
  
  package "System Management" {
    usecase "Global Search" as UC25
    usecase "Manage Report Signatures" as UC26
    usecase "Upload Courses" as UC27
    usecase "System Edit" as UC28
