' ============================================================================
' 3.3.2 ENTITY RELATIONSHIP DIAGRAM (ERD)
' ============================================================================
@startuml 3.3.2_erd_diagram
skinparam shadowing false
skinparam linetype ortho
skinparam class {
  BackgroundColor LightYellow
  BorderColor Black
}

class User {
  * id : PK
  --
  * name
  * role
  faculty : FK
}

class Student {
  * student_id : PK
  --
  * name
  * national_id
  * faculty_code : FK
  department
  level
  gpa
  status
  regulation
}

class Faculty {
  * id : PK
  --
  * name
  * code
  student_count
  staff_count
}

class AcademicFaculty {
  * id : PK
  --
  * name
  * code
  dean_id
  departments
}

class AcademicDepartment {
  * id : PK
  --
  * name
  * code
  * faculty_id : FK
  head_id
  programs
}

class AcademicProgram {
  * id : PK
  --
  * name
  * code
  * degree
  * department_id : FK
  total_hours
  mandatory_hours
  elective_hours
  tracks
}

class StudyRegulation {
  * id : PK
  --
  * name
  * program_id : FK
  registration_rules
  pass_fail_rules
  absence_policy
}

class AcademicRules {
  * id : PK
  --
  * faculty_id : FK
  faculty_name
  study_system
  graduation_requirements
  level_progression
  evaluation_system
  retake_rules
  program_change
  scientific_trips
  created_at
  updated_at
}

class AcademicCourse {
  * id : PK
  --
  * code
  * name
  * program_id : FK
  theoretical_hours
  practical_hours
  credit_hours
  level
  type
  prerequisites
}

class Schedule {
  * schedule_id : PK
  --
  * course_id : FK
  semester
  academic_year
  * faculty : FK
  level
  room
  room_type
  room_capacity
  instructor
  day
  time
}

class Enrollment {
  * enrollment_id : PK
  --
  * student_id : FK
  * course_code : FK
  group
  registration_date
  status
}

class RegistrationIssue {
  * req_id : PK
  --
  * student_id : FK
  date
  comment
  status
}

class Grade {
  * grade_id : PK
  --
  * student_id : FK
  * course_code : FK
  semester
  grade
  points
}

class Attendance {
  * attendance_id : PK
  --
  * student_id : FK
  * course
  session_type
  week
  status
  date
}

class Fees {
  * fee_id : PK
  --
  * student_id : FK
  item
  amount
  paid
  remaining
  status
}

class StudentProfile {
  * id : PK
  --
  * student_id : FK
  personal_data
  contact_data
  family_data
  qualification_data
  military_data
  medical_data
}

class Committee {
  * id : PK
  --
  * name
  * course_id : FK
  * room_id : FK
  capacity
  assigned_students
  status
  seating_arrangement
}

class StudentCommitteeAssignment {
  * id : PK
  --
  * student_id : FK
  * committee_id : FK
  seat_number
  row
  column
  exam_date
  exam_time
}

class Classroom {
  * id : PK
  --
  * code
  * name
  type
  capacity
  building
  floor
  status
}

class Lab {
  * id : PK
  --
  * code
  * name
  type
  capacity
  equipment
  status
}

class ActivityLog {
  * id : PK
  --
  timestamp
  user
  action
  entity
  details
  faculty
}

class ReportSignature {
  * id : PK
  --
  report_name
  signatory_name
  title
  order
  is_active
}

' Relationships
User "1" --> "0..*" Student : "has role"
Faculty "1" --> "0..*" Student : "belongs to"
AcademicFaculty "1" --> "0..*" AcademicDepartment : "contains"
AcademicDepartment "1" --> "0..*" AcademicProgram : "has"
AcademicProgram "1" --> "0..1" StudyRegulation : "follows"
Faculty "1" --> "0..*" AcademicRules : "defines rules"
AcademicRules "1" --> "0..*" AcademicCourse : "contains courses"
AcademicProgram "1" --> "0..*" AcademicCourse : "has"
AcademicCourse "1" --> "0..*" Schedule : "scheduled in"
Student "1" --> "0..*" Enrollment : "enrolls"
AcademicCourse "1" --> "0..*" Enrollment : "enrolled by"
Student "1" --> "0..*" Grade : "receives"
AcademicCourse "1" --> "0..*" Grade : "graded for"
Student "1" --> "0..*" Attendance : "has"
AcademicCourse "1" --> "0..*" Attendance : "attended in"
Student "1" --> "0..*" Fees : "has"
Student "1" --> "0..1" StudentProfile : "has profile"
Student "1" --> "0..*" RegistrationIssue : "has"
AcademicCourse "1" --> "0..*" Committee : "examined in"
Student "1" --> "0..*" StudentCommitteeAssignment : "assigned to"
Committee "1" --> "0..*" StudentCommitteeAssignment : "has assignment"
Committee "0..*" --> "1" Classroom : "uses room"
Committee "0..*" --> "1" Lab : "uses lab"

@enduml

