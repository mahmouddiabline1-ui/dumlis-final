# Backend Production Environment
# ⚠️ تم تعيين هذه المتغيرات في Render Dashboard، لا تضع القيم الحقيقية هنا!

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security
SECRET_KEY=your-secret-key-here-min-32-characters

# Server
HOST=0.0.0.0
PORT=8000
APP_ENV=production
DEBUG=False

# CORS
ALLOWED_ORIGINS=https://your-cloudflare-domain.pages.dev,https://your-domain.com

# API Keys
GROQ_API_KEY=your-groq-key-here
GEMINI_API_KEY=your-gemini-key-here
