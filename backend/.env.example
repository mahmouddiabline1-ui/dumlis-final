# Environment Configuration for DUMLIS FastAPI Backend
# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://dumlis_user:your_password@localhost:5432/dumlis_db

# Secret key for JWT token signing (generate with: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-very-long-random-secret-key

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Server settings
HOST=0.0.0.0
PORT=8000

# Groq API Key for AI features
GROQ_API_KEY=your-groq-api-key-here
